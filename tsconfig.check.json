{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "lib": [
      "ES2022",
      "DOM"
    ],
    "skipLibCheck": true
  },
  "include": [
    ".astro/types.d.ts",
    "src/lib/content/**/*.ts",
    "src/scripts/**/*.ts",
    "tests/**/*.ts",
    "eslint.config.js"
  ]
}
