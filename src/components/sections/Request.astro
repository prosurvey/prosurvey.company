---
import { applyTypographyNbsp } from "../../lib/typography";

type Props = {
  id: string;
  title: string;
  description: string;
  imageHref: string;
  submitText: string;
  recipientEmail: string;
  fields: {
    name: { label: string; required: boolean };
    phone: { label: string; required: boolean };
    email: { label: string; required: boolean };
    message: { label: string; required: boolean };
    consent: { label: string; required: boolean };
  };
  messages: {
    success: string;
  };
  consentLinks: {
    privacy: { text: string; href: string };
    terms: { prefix: string; text: string; href: string };
  };
};

const {
  id,
  title,
  description,
  imageHref,
  submitText,
  fields,
  messages,
  consentLinks,
} = Astro.props;

const requestTitle = applyTypographyNbsp(title);
const requestDescription = applyTypographyNbsp(description);
const successMessage = applyTypographyNbsp(messages.success);
const termsPrefixText = applyTypographyNbsp(consentLinks.terms.prefix);
---

<section id={id} class="request">
  <div class="container">
    <div class="request__grid">
      <div class="request__content">
        <p class="request__eyebrow">Заявка</p>
        <h2 class="request__title">{requestTitle}</h2>
        <p class="request__description">{requestDescription}</p>
      </div>

      <div class="request__card">
        <form class="request-form" data-request-form novalidate>
          <input type="hidden" name="source" value="site-form" />

          <div class="request-form__field">
            <label for={`${id}-name`}>{fields.name.label}</label>
            <input
              id={`${id}-name`}
              name="name"
              type="text"
              autocomplete="name"
              required={fields.name.required}
            />
          </div>

          <div class="request-form__field">
            <label for={`${id}-phone`}>{fields.phone.label}</label>
            <input
              id={`${id}-phone`}
              name="phone"
              type="tel"
              autocomplete="tel"
              required={fields.phone.required}
            />
          </div>

          <div class="request-form__field">
            <label for={`${id}-email`}>{fields.email.label}</label>
            <input
              id={`${id}-email`}
              name="email"
              type="email"
              autocomplete="email"
              required={fields.email.required}
            />
          </div>

          <div class="request-form__field">
            <label for={`${id}-company`}>Компания</label>
            <input
              id={`${id}-company`}
              name="company"
              type="text"
              autocomplete="organization"
            />
          </div>

          <div class="request-form__field">
            <label for={`${id}-message`}>{fields.message.label}</label>
            <textarea
              id={`${id}-message`}
              name="message"
              rows="5"
              required={fields.message.required}
            ></textarea>
          </div>

          <label class="request-form__consent">
            <input
              name="consent"
              type="checkbox"
              value="yes"
              required={fields.consent.required}
            />
            <span>
              Я внимательно прочитал
              <a href={consentLinks.privacy.href} target="_blank" rel="noopener noreferrer">
                {consentLinks.privacy.text}
              </a>
              {" "}и даю свое согласие на обработку персональных данных
            </span>
          </label>

          <button type="submit" class="request-form__submit" data-submit-button>
            {submitText}
          </button>

          <p class="request-form__terms">
            {termsPrefixText}{" "}
            <a href={consentLinks.terms.href} target="_blank" rel="noopener noreferrer">
              {consentLinks.terms.text}
            </a>
          </p>

          <div class="request-form__status" data-status hidden></div>
        </form>
      </div>
    </div>
  </div>

  <style>
    .request {
      padding: 96px 0;
      background:
        linear-gradient(180deg, rgba(24, 24, 24, 0.96), rgba(24, 24, 24, 0.96)),
        url({imageHref}) center / cover no-repeat;
    }

    .container {
      width: min(1200px, calc(100% - 32px));
      margin: 0 auto;
    }

    .request__grid {
      display: grid;
      grid-template-columns: 1fr 1.1fr;
      gap: 32px;
      align-items: start;
    }

    .request__eyebrow {
      margin: 0 0 12px;
      color: rgba(255, 255, 255, 0.72);
      font-size: 14px;
      line-height: 1.2;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .request__title {
      margin: 0 0 16px;
      color: #fff;
      font-size: clamp(32px, 4vw, 56px);
      line-height: 1;
    }

    .request__description {
      margin: 0;
      color: rgba(255, 255, 255, 0.84);
      font-size: 18px;
      line-height: 1.5;
      max-width: 560px;
    }

    .request__card {
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 28px;
      background: rgba(20, 20, 20, 0.8);
      backdrop-filter: blur(16px);
      padding: 24px;
    }

    .request-form {
      display: grid;
      gap: 16px;
    }

    .request-form__field {
      display: grid;
      gap: 8px;
    }

    .request-form__field label,
    .request-form__terms,
    .request-form__consent {
      color: rgba(255, 255, 255, 0.84);
      font-size: 14px;
      line-height: 1.5;
    }

    .request-form__field input,
    .request-form__field textarea {
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.04);
      color: #fff;
      padding: 16px 18px;
      font: inherit;
      outline: none;
      resize: vertical;
      box-sizing: border-box;
    }

    .request-form__field input:focus,
    .request-form__field textarea:focus {
      border-color: rgba(114, 66, 92, 0.9);
      box-shadow: 0 0 0 3px rgba(114, 66, 92, 0.18);
    }

    .request-form__consent {
      display: flex;
      gap: 12px;
      align-items: flex-start;
    }

    .request-form__consent input {
      margin-top: 3px;
      flex: 0 0 auto;
    }

    .request-form__consent a,
    .request-form__terms a {
      color: #fff;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .request-form__submit {
      width: 100%;
      border: 0;
      border-radius: 22px;
      padding: 20px 24px;
      background: #72425c;
      color: #fff;
      font: inherit;
      font-size: 20px;
      font-weight: 700;
      cursor: pointer;
      transition: opacity 0.2s ease;
    }

    .request-form__submit:disabled {
      cursor: wait;
      opacity: 0.72;
    }

    .request-form__status {
      border-radius: 18px;
      padding: 18px 20px;
      font-size: 16px;
      line-height: 1.5;
    }

    .request-form__status.is-success {
      border: 1px solid rgba(37, 179, 105, 0.45);
      background: rgba(20, 72, 44, 0.32);
      color: #e8fff1;
    }

    .request-form__status.is-error {
      border: 1px solid rgba(255, 107, 107, 0.4);
      background: rgba(90, 20, 20, 0.28);
      color: #ffe9e9;
    }

    @media (max-width: 900px) {
      .request {
        padding: 72px 0;
      }

      .request__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script>
    (() => {
      const root = document.currentScript?.closest("section");
      if (!root) return;

      const form = root.querySelector("[data-request-form]");
      const status = root.querySelector("[data-status]");
      const submitButton = root.querySelector("[data-submit-button]");

      if (!(form instanceof HTMLFormElement)) return;
      if (!(status instanceof HTMLElement)) return;
      if (!(submitButton instanceof HTMLButtonElement)) return;

      const successMessage = {JSON.stringify(successMessage)};
      const errorMessage =
        "Не удалось отправить заявку. Попробуйте еще раз или свяжитесь с нами по телефону.";

      const setStatus = (type, message) => {
        status.hidden = false;
        status.textContent = message;
        status.classList.remove("is-success", "is-error");
        status.classList.add(type === "success" ? "is-success" : "is-error");
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!form.reportValidity()) return;

        submitButton.disabled = true;
        const initialText = submitButton.textContent ?? "";
        submitButton.textContent = "Отправляем...";

        try {
          const formData = new FormData(form);
          const payload = Object.fromEntries(formData.entries());

          const response = await fetch("/api/lead", {
            method: "POST",
            headers: {
              "content-type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          const data = await response.json().catch(() => null);

          if (!response.ok || !data?.ok) {
            throw new Error(data?.error || "submit_failed");
          }

          form.reset();
          setStatus("success", successMessage);
        } catch (error) {
          console.error(error);
          setStatus("error", errorMessage);
        } finally {
          submitButton.disabled = false;
          submitButton.textContent = initialText;
        }
      });
    })();
  </script>
</section>
