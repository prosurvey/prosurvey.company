---
import Icon from "../Icon.astro";

type Props = {
  id: string;
  title: string;
  subtitle: string;
  main: string[];
  other: string[];
};

const { id, title, subtitle, main, other } = Astro.props;
---

<section id={id} class="section section--light">
  <div class="container services">
    <h2 class="h2">{title}</h2>
    <p class="lead services__subtitle">{subtitle}</p>

    <div class="services__grid">
      <div class="services__col">
        <h3 class="services__h3">Основные услуги</h3>
        <ul class="services__main">
          {main.map((item) => (
            <li class="services__main-item">
              <Icon name="check" class="services__check" size={20} />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="services__col">
        <h3 class="services__h3">Дополнительно</h3>
        <ul class="services__other">
          {other.map((item) => (
            <li class="services__pill">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .services__subtitle {
    white-space: pre-line;
    max-width: 920px;
  }

  .services__grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 26px;
    align-items: start;
  }

  .services__h3 {
    margin: 0 0 12px;
    font-size: 18px;
    letter-spacing: -0.01em;
  }

  .services__main {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .services__main-item {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    line-height: 1.45;
    padding: 10px 12px;
    border-radius: 14px;
    border: 1px solid rgba(16, 17, 18, 0.08);
    background: #fff;
  }

  .services__check {
    color: var(--accent);
    flex: 0 0 auto;
    margin-top: 1px;
  }

  .services__other {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .services__pill {
    border: 1px solid rgba(16, 17, 18, 0.1);
    background: rgba(255, 255, 255, 0.7);
    border-radius: 999px;
    padding: 10px 14px;
    line-height: 1.2;
  }

  @media (max-width: 980px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

