---
import Icon from "../Icon.astro";

type Props = {
  id: string;
  title: string;
  email: string;
  phoneText: string;
  phoneHref: string;
  hours: string;
  socials: Array<{ type: "mail" | "telegram" | "whatsapp"; href: string; label: string }>;
};

const { id, title, email, phoneText, phoneHref, hours, socials } = Astro.props;

const socialOrder: Record<"mail" | "telegram" | "whatsapp", number> = {
  telegram: 0,
  whatsapp: 1,
  mail: 2,
};

const socialItems = socials
  .filter((item) => item.type !== "mail")
  .sort((a, b) => socialOrder[a.type] - socialOrder[b.type]);
---

<section id={id} class="section section--dark contacts">
  <div class="ds-container contacts__inner">
    <div class="contacts__copy">
      <h2 class="ds-container__title contacts__title">{title}</h2>

      <div class="contacts__hours" aria-label="Режим работы">
        <Icon name="clock" size={18} class="contacts__icon contacts__icon--muted" />
        <span class="contacts__hours-label">Режим работы</span>
        <span class="contacts__hours-separator" aria-hidden="true">·</span>
        <span class="contacts__hours-value">{hours}</span>
      </div>

      <div class="contacts__primary">
        <a class="contacts__line" href={`tel:${phoneHref}`}>
          <Icon name="phone" size={18} class="contacts__icon" />
          <span class="contacts__line-text">{phoneText}</span>
        </a>

        <a class="contacts__line" href={`mailto:${email}`}>
          <Icon name="mail" size={18} class="contacts__icon" />
          <span class="contacts__line-text">{email}</span>
        </a>
      </div>

      <div class="contacts__socials" aria-label="Соцсети">
        {socialItems.map((s) => (
          <a
            class="ds-social contacts__social"
            href={s.href}
            target={s.href.startsWith("http") ? "_blank" : "_self"}
            rel={s.href.startsWith("http") ? "noopener noreferrer nofollow" : undefined}
          >
            <Icon name={s.type} size={20} />
            <span>{s.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contacts__inner {
    display: grid;
    justify-items: stretch;
  }

  .contacts__copy {
    width: 100%;
    max-width: 960px;
    margin-inline: auto;
    border-radius: var(--radius-l);
    border: 1px solid var(--border-on-dark);
    background: rgb(var(--text-light-rgb) / 0.03);
    box-shadow: var(--shadow-sm);
    padding: clamp(18px, 3.6vw, 42px);
    text-align: left;
  }

  .contacts__copy :global(.ds-container__title) {
    text-align: center;
    margin: 0;
  }

  .contacts__copy {
    display: grid;
    gap: 12px;
  }

  .contacts__title {
    margin: 0;
    justify-self: center;
    width: 100%;
  }

  .contacts__hours {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgb(var(--text-light-rgb) / 0.76);
    min-height: 26px;
    justify-self: start;
    white-space: nowrap;
  }

  .contacts__hours-label {
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgb(var(--text-light-rgb) / 0.56);
    white-space: nowrap;
  }

  .contacts__hours-separator {
    color: rgb(var(--text-light-rgb) / 0.4);
  }

  .contacts__hours-value {
    font-size: 16px;
    line-height: 1.45;
    color: rgb(var(--text-light-rgb) / 0.8);
  }

  .contacts__primary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 10px;
  }

  .contacts__line {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 48px;
    padding: 11px 14px;
    border-radius: var(--radius-s);
    border: 1px solid rgb(var(--text-light-rgb) / 0.16);
    background: rgb(var(--text-light-rgb) / 0.06);
    color: rgb(var(--text-light-rgb) / 0.9);
    font-size: clamp(16px, 1.2vw + 12px, 18px);
    line-height: 1.5;
    text-decoration: none;
    width: 100%;
    min-width: 0;
  }

  .contacts__icon {
    display: inline-flex;
    color: rgb(var(--text-light-rgb) / 0.88);
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }

  .contacts__icon--muted {
    color: rgb(var(--text-light-rgb) / 0.62);
  }

  .contacts__line-text {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  a.contacts__line {
    transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
  }

  a.contacts__line:hover {
    border-color: rgb(var(--text-light-rgb) / 0.24);
    background: rgb(var(--text-light-rgb) / 0.1);
    color: rgb(var(--text-light-rgb) / 0.94);
    box-shadow: var(--shadow-xs);
  }

  a.contacts__line:focus-visible {
    outline: 3px solid rgb(var(--accent-rgb) / 0.24);
    outline-offset: 3px;
  }

  .contacts__socials {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .contacts__social :global(svg) {
    width: 18px;
    height: 18px;
  }

  @media (min-width: 980px) {
    .contacts__copy {
      grid-template-columns: minmax(220px, 300px) minmax(0, 1fr);
      column-gap: 28px;
      row-gap: 14px;
      align-items: start;
    }

    .contacts__title {
      grid-column: 1 / -1;
      align-self: start;
      justify-self: center;
      margin-bottom: 2px;
    }

    .contacts__hours {
      grid-column: 2;
      align-self: end;
      min-height: 52px;
      font-size: 17px;
    }

    .contacts__hours-value {
      font-size: 17px;
    }

    .contacts__primary {
      grid-column: 2;
    }

    .contacts__socials {
      grid-column: 2;
    }
  }

  @media (max-width: 639px) {
    .contacts__hours {
      white-space: normal;
      row-gap: 2px;
      flex-wrap: wrap;
    }
  }
</style>
