---
import Icon from "../Icon.astro";

type Props = {
  id: string;
  title: string;
  email: string;
  phoneText: string;
  phoneHref: string;
  hours: string;
  address: string;
  socials: Array<{ type: "mail" | "telegram" | "whatsapp"; href: string; label: string }>;
  imageHref: string;
};

const { id, title, email, phoneText, phoneHref, hours, address, socials, imageHref } = Astro.props;
---

<section id={id} class="section section--dark">
  <div class="container contacts">
    <div class="contacts__grid">
      <div class="contacts__copy">
        <p class="eyebrow">Связаться</p>
        <h2 class="h2">{title}</h2>

        <div class="contacts__details">
          <a class="contacts__line" href={`mailto:${email}`}>{email}</a>
          <div class="contacts__line">{hours}</div>
          <a class="contacts__line" href={`tel:${phoneHref}`}>{phoneText}</a>
          <div class="contacts__line contacts__address">{address}</div>
        </div>

        <div class="contacts__socials" aria-label="Соцсети">
          {socials.map((s) => (
            <a class="contacts__social btn btn-secondary" href={s.href} target={s.href.startsWith("http") ? "_blank" : "_self"} rel="nofollow">
              <Icon name={s.type} size={20} />
              <span>{s.label}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="contacts__media card">
        <img class="contacts__image" src={imageHref} alt="" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

<style>
  .contacts__grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 22px;
    align-items: stretch;
  }

  .contacts__details {
    margin-top: 18px;
    display: grid;
    gap: 10px;
    color: rgba(248, 249, 250, 0.86);
    font-size: 18px;
    line-height: 1.4;
  }

  .contacts__line {
    color: inherit;
  }

  .contacts__address {
    color: var(--muted-on-dark);
    white-space: pre-line;
  }

  .contacts__socials {
    margin-top: 22px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .contacts__social {
    gap: 8px;
    padding: 12px 16px;
  }

  .contacts__media {
    padding: 0;
    overflow: hidden;
  }

  .contacts__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 360px;
    filter: saturate(0.95) contrast(1.05);
  }

  @media (max-width: 980px) {
    .contacts__grid {
      grid-template-columns: 1fr;
    }

    .contacts__image {
      min-height: 280px;
    }
  }
</style>

