---
type Props = {
  title: string;
  text: string;
  imageHref: string;
  buttons: Array<{ text: string; href: string; variant?: "primary" | "secondary" }>;
};

const { title, text, imageHref, buttons } = Astro.props;
---

<section class="hero" aria-label="Главный экран">
  <img class="hero__bg" src={imageHref} alt="" loading="eager" decoding="async" />
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__content">
    <div class="hero__content-wrapper">
      <h1 class="hero__title">{title}</h1>
      <p class="hero__text">{text}</p>
      <div class="hero__actions">
        {buttons.map((button, idx) => {
          const variant = button.variant ?? (idx === 0 ? "secondary" : "primary");
          const btnClass = variant === "primary" ? "btn-primary" : "btn-secondary";
          return (
            <a class={`btn hero__btn ${btnClass}`} href={button.href}>
              {button.text}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.01);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgb(var(--bg-dark-rgb) / 0.84) 0%,
      rgb(var(--bg-dark-rgb) / 0.66) 42%,
      rgb(var(--bg-dark-rgb) / 0.78) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    min-height: clamp(520px, calc(92svh - var(--header-height)), 860px);
    padding-block: clamp(54px, 11vw, 120px);
    padding-inline: clamp(18px, 4vw, 32px);
  }

  .hero__content-wrapper {
    width: min(920px, 100%);
    margin-inline: auto;
    text-align: left;
  }

  .hero__title {
    margin: 0 0 12px;
    color: var(--text-light);
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 52px);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.06;
    text-shadow: 0 8px 28px rgb(0 0 0 / 0.2);
    white-space: pre-line;
  }

  .hero__text {
    margin: 0;
    font-size: clamp(16px, 1.3vw + 10px, 20px);
    font-weight: 400;
    line-height: 1.6;
    color: rgb(var(--text-light-rgb) / 0.84);
    white-space: pre-line;
    max-width: 34ch;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    margin-top: 24px;
    width: min(340px, 100%);
  }

  .hero__btn {
    width: 100%;
    font-size: 16px;
    font-weight: 600;
    line-height: 22px;
    text-decoration: none;
  }

  @media (min-width: 620px) and (max-width: 1023px) {
    .hero__content {
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - var(--header-height));
      padding-block: clamp(92px, 12vw, 160px);
    }

    .hero__content-wrapper {
      text-align: center;
    }

    .hero__text {
      max-width: 52ch;
      margin-inline: auto;
    }

    .hero__actions {
      align-items: center;
      width: auto;
      margin-top: 24px;
    }

    .hero__btn {
      min-width: 196px;
      width: auto;
    }
  }

  @media (min-width: 1024px) {
    .hero__content {
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - var(--header-height));
      padding-block: clamp(120px, 14vw, 200px);
    }

    .hero__content-wrapper {
      text-align: center;
    }

    .hero__text {
      max-width: 58ch;
      margin-inline: auto;
    }

    .hero__actions {
      flex-direction: row;
      justify-content: center;
      gap: 12px;
      margin-top: 30px;
      width: auto;
    }

    .hero__btn {
      min-width: 168px;
      width: auto;
    }
  }
</style>
