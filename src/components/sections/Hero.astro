---
type Props = {
  title: string;
  text: string;
  imageHref: string;
  buttons: Array<{ text: string; href: string; variant?: "primary" | "secondary" }>;
};

const { title, text, imageHref, buttons } = Astro.props;
---

<section class="hero" aria-label="Главный экран">
  <img class="hero__bg" src={imageHref} alt="" loading="eager" decoding="async" />
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__content">
    <div class="hero__content-wrapper">
      <h1 class="hero__title">{title}</h1>
      <p class="hero__text">{text}</p>
      <div class="hero__actions">
        {buttons.map((button, idx) => (
          <a
            class={`btn hero__btn ${idx === 0 ? "hero__btn--secondary-inverse" : "hero__btn--primary-inverse"}`}
            href={button.href}
          >
            {button.text}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.01);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6));
  }

  .hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 192px 24px;
  }

  @media (min-width: 620px) and (max-width: 1023px) {
    .hero__content {
      padding: 228px 0;
    }
  }

  @media (min-width: 1024px) {
    .hero__content {
      padding: 292px 0;
    }
  }

  .hero__content-wrapper {
    text-align: center;
    width: 100%;
  }

  @media (min-width: 620px) and (max-width: 1023px) {
    .hero__content-wrapper {
      max-width: 525px;
    }
  }

  @media (min-width: 1024px) {
    .hero__content-wrapper {
      max-width: 663px;
    }
  }

  .hero__title {
    color: var(--text-light);
    display: block;
    font-size: 24px;
    font-style: normal;
    font-weight: 500;
    letter-spacing: -0.12px;
    line-height: 26px;
    margin: 0 0 8px;
    text-shadow: 0 0 12px rgba(43, 45, 51, 0.32);
    white-space: pre-line;
  }

  @media (min-width: 620px) and (max-width: 1023px) {
    .hero__title {
      font-size: 32px;
      font-style: normal;
      font-weight: 500;
      letter-spacing: -0.32px;
      line-height: 32px;
      margin-bottom: 12px;
    }
  }

  @media (min-width: 1024px) {
    .hero__title {
      font-size: 44px;
      font-style: normal;
      font-weight: 500;
      letter-spacing: -0.44px;
      line-height: 44px;
      margin-bottom: 16px;
    }
  }

  .hero__text {
    margin: 0;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 26px;
    color: var(--muted-on-dark);
    text-decoration-line: none;
    white-space: pre-line;
  }

  @media (min-width: 1024px) {
    .hero__text {
      font-size: 20px;
      font-style: normal;
      font-weight: 400;
      line-height: 28px;
      text-decoration-line: none;
    }
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 16px;
    align-items: center;
  }

  @media (min-width: 620px) and (max-width: 1023px) {
    .hero__actions {
      margin-top: 24px;
    }
  }

  @media (min-width: 1024px) {
    .hero__actions {
      flex-direction: row;
      gap: 12px;
      justify-content: center;
      margin-top: 32px;
    }
  }

  .hero__btn {
    border-radius: 12px;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px;
    padding: 13px 18px;
    text-decoration-line: none;
  }

  @media (min-width: 1024px) {
    .hero__btn {
      font-size: 18px;
      line-height: 26px;
    }
  }

  .hero__btn:active {
    transform: none;
  }

  .hero__btn--secondary-inverse {
    backdrop-filter: blur(22px);
    background-color: hsla(0, 0%, 100%, 0.1);
    color: var(--text-light);
  }

  .hero__btn--secondary-inverse:hover {
    background-color: hsla(0, 0%, 100%, 0.2);
  }

  .hero__btn--secondary-inverse:active {
    background-color: hsla(0, 0%, 100%, 0.2);
  }

  .hero__btn--primary-inverse {
    background-color: hsla(0, 0%, 100%, 0.9);
    color: #232323;
  }

  .hero__btn--primary-inverse:hover {
    background-color: #fff;
  }

  .hero__btn--primary-inverse:active {
    background-color: #fff;
  }
</style>
