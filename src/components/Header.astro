---
type Props = {
  logoHref: string;
  logoAlt: string;
  navItems: Array<{ text: string; href: string }>;
  cta: { text: string; href: string };
};

const { logoHref, logoAlt, navItems, cta } = Astro.props;
---

<header class="header">
  <div class="header__wrapper">
    <div class="header__content">
      <div class="header__group header__group--left">
        <a class="header__logo" href="/">
          <img src={logoHref} alt={logoAlt} width="200" height="56" loading="eager" />
        </a>

        <nav class="nav nav--desktop" aria-label="Главное меню">
          <ul class="nav__list">
            {navItems.map((item) => (
              <li class="nav__item">
                <a class="nav__link" href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <div class="header__group header__group--right">
        <a class="btn btn-primary header__cta" href={cta.href}>{cta.text}</a>

        <details class="nav-mobile">
          <summary class="nav-mobile__summary" aria-label="Меню">
            <span class="nav-mobile__icon" aria-hidden="true"></span>
          </summary>
          <nav class="nav-mobile__panel" aria-label="Меню (мобильное)">
            <ul class="nav-mobile__list">
              {navItems.map((item) => (
                <li class="nav-mobile__item">
                  <a class="nav-mobile__link" href={item.href}>{item.text}</a>
                </li>
              ))}
              <li class="nav-mobile__item nav-mobile__item--cta">
                <a class="btn btn-primary nav-mobile__cta" href={cta.href}>{cta.text}</a>
              </li>
            </ul>
          </nav>
        </details>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 200;
    height: var(--header-height);
    background: var(--bg-dark);
  }

  .header__wrapper {
    height: 100%;
    width: 100%;
    padding: 0 16px;
    box-shadow:
      0 1px 2px rgba(43, 45, 51, 0.08),
      0 4px 12px rgba(43, 45, 51, 0.04);
  }

  .header__content {
    height: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .header__group {
    display: flex;
    align-items: center;
  }

  .header__group--left {
    gap: 40px;
    justify-content: flex-start;
  }

  .header__group--right {
    gap: 12px;
    justify-content: flex-end;
  }

  .header__logo img {
    height: 56px;
    max-width: 164px;
    width: auto;
    object-fit: contain;
  }

  @media (min-width: 1024px) {
    .header__logo img {
      max-width: 200px;
    }
  }

  .header__cta {
    border-radius: 12px;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 22px;
    padding: 13px 18px;
  }

  .header__cta:active {
    transform: none;
  }

  @media (min-width: 1024px) {
    .header__cta {
      font-size: 18px;
      line-height: 26px;
    }
  }

  .nav__list {
    list-style: none;
    display: flex;
    padding: 0;
    margin: 0;
    flex-direction: row;
    align-items: center;
    gap: 16px;
  }

  @media (min-width: 1200px) {
    .nav__list {
      gap: 32px;
    }
  }

  .nav__link {
    color: var(--muted-on-dark);
    font-size: 18px;
    font-weight: 400;
    line-height: 26px;
    padding: 12px 0;
    transition: color 140ms ease;
    text-decoration: none;
    text-decoration-line: none;
  }

  .nav__link:hover {
    color: var(--text-light);
    text-decoration: underline;
    text-decoration-line: underline;
  }

  .nav-mobile {
    display: none;
    position: relative;
  }

  .nav-mobile__summary {
    list-style: none;
    cursor: pointer;
    border: 1px solid var(--border-on-dark);
    border-radius: 999px;
    height: 42px;
    width: 42px;
    display: grid;
    place-items: center;
    background: rgba(16, 17, 18, 0.5);
  }

  .nav-mobile__summary::-webkit-details-marker {
    display: none;
  }

  .nav-mobile__icon {
    width: 18px;
    height: 12px;
    position: relative;
  }

  .nav-mobile__icon::before,
  .nav-mobile__icon::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--text-light);
    border-radius: 999px;
  }

  .nav-mobile__icon::before {
    top: 0;
    box-shadow: 0 5px 0 var(--text-light);
  }

  .nav-mobile__icon::after {
    bottom: 0;
  }

  .nav-mobile[open] .nav-mobile__panel {
    display: block;
  }

  .nav-mobile__panel {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 12px);
    width: min(320px, calc(100vw - 40px));
    border-radius: var(--radius-m);
    border: 1px solid var(--border-on-dark);
    background: rgba(16, 17, 18, 0.92);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
    padding: 12px;
  }

  .nav-mobile__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }

  .nav-mobile__link {
    display: block;
    padding: 12px 12px;
    border-radius: 12px;
    color: var(--text-light);
    transition: background-color 140ms ease;
  }

  .nav-mobile__link:hover {
    background: rgba(248, 249, 250, 0.08);
  }

  .nav-mobile__item--cta {
    padding-top: 8px;
  }

  .nav-mobile__cta {
    width: 100%;
  }

  @media (max-width: 980px) {
    .nav--desktop {
      display: none;
    }

    .header__cta {
      display: none;
    }

    .nav-mobile {
      display: block;
    }
  }

  @media (min-width: 620px) and (max-width: 1023px) {
    .header__wrapper {
      padding: 0 24px;
    }
  }

  @media (min-width: 1024px) {
    .header__wrapper {
      padding: 0 24px;
    }
  }
</style>
