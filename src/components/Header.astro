---
type Props = {
  logoHref: string;
  logoAlt: string;
  navItems: Array<{ text: string; href: string }>;
  cta: { text: string; href: string };
};

const { logoHref, logoAlt, navItems, cta } = Astro.props;
const homeHref = import.meta.env.BASE_URL ?? "/";
---

<header class="header">
  <div class="header__wrapper">
    <div class="header__content">
      <div class="header__group header__group--left">
        <a class="header__logo" href={homeHref}>
          <img src={logoHref} alt={logoAlt} width="200" height="56" loading="eager" />
        </a>

        <nav class="nav nav--desktop" aria-label="Главное меню">
          <ul class="nav__list">
            {navItems.map((item) => (
              <li class="nav__item">
                <a class="nav__link" href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <div class="header__group header__group--right">
        <a class="btn btn-primary header__cta" href={cta.href}>{cta.text}</a>

        <details class="nav-mobile" data-nav-mobile>
          <summary class="nav-mobile__summary" aria-label="Меню" aria-expanded="false">
            <span class="nav-mobile__icon" aria-hidden="true"></span>
          </summary>
          <nav class="nav-mobile__panel" aria-label="Меню (мобильное)">
            <ul class="nav-mobile__list">
              {navItems.map((item) => (
                <li class="nav-mobile__item">
                  <a class="nav-mobile__link" href={item.href}>{item.text}</a>
                </li>
              ))}
              <li class="nav-mobile__item nav-mobile__item--cta">
                <a class="btn btn-primary nav-mobile__cta" href={cta.href}>{cta.text}</a>
              </li>
            </ul>
          </nav>
        </details>
      </div>
    </div>
  </div>
</header>

<script>
  const initMobileMenu = () => {
    const menus = Array.from(document.querySelectorAll('[data-nav-mobile]'));
    if (menus.length === 0) return;

    menus.forEach((menu) => {
      if (!(menu instanceof HTMLDetailsElement)) return;
      if (menu.dataset.menuReady === 'true') return;
      menu.dataset.menuReady = 'true';

      const summary = menu.querySelector('.nav-mobile__summary');
      if (!(summary instanceof HTMLElement)) return;

      const closeMenu = () => {
        if (!menu.open) return;
        menu.open = false;
      };

      const syncExpanded = () => {
        summary.setAttribute('aria-expanded', menu.open ? 'true' : 'false');
      };

      syncExpanded();
      menu.addEventListener('toggle', syncExpanded);

      document.addEventListener(
        'pointerdown',
        (event) => {
          if (!menu.open) return;
          const target = event.target;
          if (target instanceof Node && menu.contains(target)) return;
          closeMenu();
        },
        { passive: true }
      );

      window.addEventListener(
        'scroll',
        () => {
          if (!menu.open) return;
          closeMenu();
        },
        { passive: true }
      );

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMenu();
        }
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });

      const mediaQuery = window.matchMedia('(min-width: 981px)');
      const closeOnDesktop = (event) => {
        if (event.matches) {
          closeMenu();
        }
      };

      if (typeof mediaQuery.addEventListener === 'function') {
        mediaQuery.addEventListener('change', closeOnDesktop);
      } else if (typeof mediaQuery.addListener === 'function') {
        mediaQuery.addListener(closeOnDesktop);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu, { once: true });
  } else {
    initMobileMenu();
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 200;
    height: var(--header-height);
    background: rgb(var(--bg-dark-rgb) / 0.94);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-on-dark);
  }

  .header__wrapper {
    height: 100%;
    width: 100%;
    padding-inline: clamp(18px, 4vw, 32px);
  }

  .header__content {
    height: 100%;
    max-width: var(--container);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .header__group {
    display: flex;
    align-items: center;
  }

  .header__group--left {
    gap: 28px;
    justify-content: flex-start;
  }

  .header__group--right {
    gap: 12px;
    justify-content: flex-end;
  }

  .header__logo img {
    height: 52px;
    max-width: 168px;
    width: auto;
    object-fit: contain;
  }

  .header__cta {
    font-size: 15px;
    font-weight: 600;
    line-height: 20px;
    padding: 10px 16px;
    box-shadow: none;
  }

  .nav__list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    position: relative;
    color: rgb(var(--text-light-rgb) / 0.78);
    font-size: 16px;
    font-weight: 500;
    line-height: 22px;
    padding: 10px 0;
    transition: color 140ms ease;
  }

  .nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 6px;
    height: 1px;
    background: transparent;
    transition: background-color 140ms ease;
  }

  .nav__link:hover {
    color: var(--text-light);
  }

  .nav__link:hover::after {
    background: rgb(var(--accent-rgb) / 0.85);
  }

  .nav__link:focus-visible {
    outline: 3px solid rgb(var(--accent-rgb) / 0.24);
    outline-offset: 3px;
  }

  .nav-mobile {
    display: none;
    position: relative;
  }

  .nav-mobile__summary {
    list-style: none;
    cursor: pointer;
    border: 1px solid var(--border-on-dark);
    border-radius: var(--radius-sm);
    height: 42px;
    width: 42px;
    display: grid;
    place-items: center;
    background: rgb(var(--bg-dark-rgb) / 0.48);
    transition: background-color 140ms ease, border-color 140ms ease;
  }

  .nav-mobile__summary::-webkit-details-marker {
    display: none;
  }

  .nav-mobile__summary:hover {
    background: rgb(var(--bg-dark-rgb) / 0.62);
    border-color: rgb(var(--text-light-rgb) / 0.26);
  }

  .nav-mobile__summary:focus-visible {
    outline: 3px solid rgb(var(--accent-rgb) / 0.24);
    outline-offset: 3px;
  }

  .nav-mobile__icon {
    width: 18px;
    height: 12px;
    position: relative;
  }

  .nav-mobile__icon::before,
  .nav-mobile__icon::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--text-light);
    border-radius: 999px;
    transition:
      transform 180ms cubic-bezier(0.2, 0, 0, 1),
      top 180ms cubic-bezier(0.2, 0, 0, 1),
      bottom 180ms cubic-bezier(0.2, 0, 0, 1),
      box-shadow 180ms cubic-bezier(0.2, 0, 0, 1);
  }

  .nav-mobile__icon::before {
    top: 0;
    box-shadow: 0 5px 0 var(--text-light);
  }

  .nav-mobile__icon::after {
    bottom: 0;
  }

  .nav-mobile[open] .nav-mobile__summary {
    background: rgb(var(--bg-dark-rgb) / 0.68);
    border-color: rgb(var(--text-light-rgb) / 0.28);
  }

  .nav-mobile[open] .nav-mobile__icon::before {
    top: 5px;
    box-shadow: 0 0 0 transparent;
    transform: rotate(45deg);
  }

  .nav-mobile[open] .nav-mobile__icon::after {
    bottom: 5px;
    transform: rotate(-45deg);
  }

  .nav-mobile__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    width: min(320px, calc(100vw - 40px));
    border-radius: var(--radius-l);
    border: 1px solid var(--border-on-dark);
    background: rgb(var(--bg-dark-rgb) / 0.96);
    backdrop-filter: blur(8px);
    box-shadow: var(--shadow-sm);
    padding: 10px;
    opacity: 0;
    transform: translateY(-8px) scale(0.98);
    transform-origin: top right;
    pointer-events: none;
    visibility: hidden;
    transition:
      opacity 150ms ease,
      transform 180ms cubic-bezier(0.2, 0, 0, 1),
      visibility 0s linear 180ms;
  }

  .nav-mobile[open] .nav-mobile__panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
    visibility: visible;
    transition-delay: 0s;
  }

  .nav-mobile__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
  }

  .nav-mobile__link {
    display: block;
    padding: 10px 12px;
    border-radius: var(--radius-s);
    color: var(--text-light);
    transition: background-color 140ms ease;
  }

  .nav-mobile__link:hover {
    background: rgb(var(--text-light-rgb) / 0.08);
  }

  .nav-mobile__item--cta {
    padding-top: 6px;
  }

  .nav-mobile__cta {
    width: 100%;
  }

  @media (max-width: 980px) {
    .nav--desktop {
      display: none;
    }

    .header__cta {
      display: none;
    }

    .nav-mobile {
      display: block;
    }
  }

  @media (min-width: 1024px) {
    .header__logo img {
      max-width: 188px;
    }

    .header__cta {
      font-size: 16px;
      line-height: 22px;
    }
  }

  @media (min-width: 1200px) {
    .nav__list {
      gap: 20px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-mobile__summary,
    .nav-mobile__icon::before,
    .nav-mobile__icon::after,
    .nav-mobile__panel {
      transition: none !important;
    }
  }
</style>
