---
import { applyTypographyNbsp } from "../lib/typography";

type Props = {
  text: string;
  acceptText: string;
  link: { text: string; href: string };
};

const { text, acceptText, link } = Astro.props;
---

<div class="cookie" data-cookie-banner hidden>
  <div class="cookie__inner">
    <div class="cookie__text">
      <p class="cookie__p">{applyTypographyNbsp(text)}</p>
      <a class="cookie__link" href={link.href}>{link.text}</a>
    </div>
    <button class="btn btn-primary cookie__btn" type="button" data-cookie-accept>{acceptText}</button>
  </div>
</div>

<script is:inline>
  {String.raw`
    const consentCookieName = 'prosurvey_cookie_consent';
    const consentAcceptedValue = 'accepted';
    const consentMaxAge = 60 * 60 * 24 * 365;
    const legacyStorageKey = 'prosurvey_cookie_consent_v2';
    const banner = document.querySelector('[data-cookie-banner]');
    const btn = document.querySelector('[data-cookie-accept]');

    const prefersReduced = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
    const secureSuffix = window.location.protocol === 'https:' ? '; Secure' : '';

    const readCookie = (name) => {
      const prefix = `${name}=`;
      const raw = document.cookie
        .split(';')
        .map((part) => part.trim())
        .find((part) => part.startsWith(prefix));
      return raw ? decodeURIComponent(raw.slice(prefix.length)) : null;
    };

    const hasCookieConsent = () => readCookie(consentCookieName) === consentAcceptedValue;

    const persistCookieConsent = () => {
      document.cookie = `${consentCookieName}=${encodeURIComponent(consentAcceptedValue)}; Max-Age=${consentMaxAge}; Path=/; SameSite=Lax${secureSuffix}`;
      try {
        localStorage.setItem(legacyStorageKey, consentAcceptedValue);
      } catch {
        // ignore
      }
    };

    const show = () => {
      if (!banner) return;
      banner.hidden = false;
      if (prefersReduced) {
        banner.classList.add('is-visible');
        return;
      }
      requestAnimationFrame(() => {
        banner.classList.add('is-visible');
      });
    };

    const hide = () => {
      if (!banner) return;
      if (prefersReduced) {
        banner.hidden = true;
        return;
      }
      banner.classList.remove('is-visible');
      window.setTimeout(() => {
        banner.hidden = true;
      }, 220);
    };

    if (banner && btn) {
      let hasConsent = hasCookieConsent();

      // Migrate older localStorage-only consent to an actual cookie once.
      if (!hasConsent) {
        let legacyStored = null;
        try {
          legacyStored = localStorage.getItem(legacyStorageKey);
        } catch {
          // ignore
        }
        if (legacyStored === consentAcceptedValue) {
          persistCookieConsent();
          hasConsent = hasCookieConsent();
        }
      }

      if (!hasConsent) show();

      btn.addEventListener('click', () => {
        persistCookieConsent();
        hide();
      });
    }
  `}
</script>

<style>
  .cookie {
    position: fixed;
    left: clamp(12px, 2vw, 24px);
    right: clamp(12px, 2vw, 24px);
    bottom: clamp(12px, 2vw, 24px);
    z-index: 900;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .cookie.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .cookie__inner {
    max-width: min(var(--container), 980px);
    margin-inline: auto;
    border-radius: var(--radius-2xl);
    border: 1px solid rgb(var(--text-light-rgb) / 0.18);
    background:
      linear-gradient(160deg, rgb(var(--accent-rgb) / 0.1), transparent 40%),
      linear-gradient(180deg, rgb(var(--bg-dark-rgb) / 0.9), rgb(var(--bg-dark-rgb) / 0.96));
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
    box-shadow: 0 18px 40px rgb(0 0 0 / 0.32);
    padding: clamp(14px, 2vw, 20px);
    display: flex;
    gap: 14px;
    align-items: center;
    justify-content: space-between;
  }

  .cookie__text {
    display: grid;
    gap: 8px;
    color: rgb(var(--text-light-rgb) / 0.82);
    font-size: 14px;
    line-height: 1.5;
  }

  .cookie__p {
    margin: 0;
    white-space: pre-line;
  }

  .cookie__link {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    color: rgb(var(--text-light-rgb) / 0.96);
    width: fit-content;
  }

  .cookie__btn {
    flex: 0 0 auto;
    min-height: 42px;
    padding-inline: 20px;
  }

  @media (max-width: 720px) {
    .cookie__inner {
      align-items: stretch;
      flex-direction: column;
    }

    .cookie__btn {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie {
      transition: none;
    }
  }
</style>
