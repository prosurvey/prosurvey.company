---
type Props = {
  text: string;
  link: { text: string; href: string };
};

const { text, link } = Astro.props;
---

<div class="cookie" data-cookie-banner hidden>
  <div class="cookie__inner">
    <div class="cookie__text">
      <p class="cookie__p">{text}</p>
      <a class="cookie__link" href={link.href}>{link.text}</a>
    </div>
    <button class="btn btn-primary cookie__btn" type="button" data-cookie-accept>Понятно</button>
  </div>
</div>

<script is:inline>
  {String.raw`
    const key = 'prosurvey_cookie_consent';
    const banner = document.querySelector('[data-cookie-banner]');
    const btn = document.querySelector('[data-cookie-accept]');
    if (banner && btn) {
      const stored = localStorage.getItem(key);
      if (stored !== 'accepted') {
        banner.hidden = false;
      }
      btn.addEventListener('click', () => {
        localStorage.setItem(key, 'accepted');
        banner.hidden = true;
      });
    }
  `}
</script>

<style>
  .cookie {
    position: fixed;
    left: 16px;
    right: 16px;
    bottom: 16px;
    z-index: 80;
  }

  .cookie__inner {
    max-width: var(--container);
    margin-inline: auto;
    border-radius: var(--radius-l);
    border: 1px solid var(--border-on-dark);
    background: rgba(16, 17, 18, 0.92);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
    padding: 14px 14px;
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
  }

  .cookie__text {
    display: grid;
    gap: 6px;
    color: var(--muted-on-dark);
    font-size: 14px;
    line-height: 1.35;
  }

  .cookie__p {
    margin: 0;
    white-space: pre-line;
  }

  .cookie__link {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: rgba(248, 249, 250, 0.92);
    width: fit-content;
  }

  .cookie__btn {
    flex: 0 0 auto;
    padding-inline: 18px;
  }

  @media (max-width: 720px) {
    .cookie__inner {
      align-items: stretch;
      flex-direction: column;
    }

    .cookie__btn {
      width: 100%;
    }
  }
</style>

