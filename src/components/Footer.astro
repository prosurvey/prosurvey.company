---
type Props = {
  navItems: Array<{ text: string; href: string }>;
  links: Array<{ text: string; href: string }>;
  copyright: string;
};

const { navItems, links, copyright } = Astro.props;
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__grid">
      <nav class="footer__nav" aria-label="Навигация в подвале">
        <ul class="footer__nav-list">
          {navItems.map((item) => (
            <li class="footer__nav-item">
              <a class="footer__nav-link" href={item.href}>{item.text}</a>
            </li>
          ))}
        </ul>
      </nav>

      <ul class="footer__links" aria-label="Юридическая информация">
        {links.map((link) => (
          <li class="footer__links-item">
            <a class="footer__link" href={link.href}>{link.text}</a>
          </li>
        ))}
      </ul>

      <p class="footer__copyright">{copyright}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-on-dark);
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 44px 0;
  }

  .footer__grid {
    display: grid;
    gap: 18px;
    text-align: center;
  }

  .footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: row;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .footer__nav-item {
    flex: 1;
    text-align: center;
  }

  .footer__nav-link {
    color: rgb(var(--text-light-rgb) / 0.74);
    font-size: 15px;
    line-height: 20px;
    transition: color 140ms ease;
    text-decoration: none;
  }

  .footer__nav-link:hover {
    color: rgb(var(--text-light-rgb) / 0.94);
  }

  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 10px 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer__link {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    color: rgb(var(--text-light-rgb) / 0.72);
    font-size: 14px;
    line-height: 20px;
    transition: color 140ms ease;
  }

  .footer__link:hover {
    color: rgb(var(--text-light-rgb) / 0.94);
  }

  @media (min-width: 620px) {
    .footer {
      padding: 36px 0;
    }

    .footer__grid {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "nav links"
        "copy copy";
      align-items: center;
      text-align: left;
      gap: 14px 18px;
    }

    .footer__nav {
      grid-area: nav;
    }

    .footer__links {
      grid-area: links;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 8px 14px;
      align-items: center;
    }

    .footer__copyright {
      grid-area: copy;
      text-align: left;
    }

    .footer__nav-list {
      flex-direction: row;
      gap: 12px 18px;
      justify-content: flex-start;
      align-items: center;
    }

    .footer__nav-item {
      flex: 0 0 auto;
      text-align: left;
    }
  }

  .footer__nav-link:focus-visible,
  .footer__link:focus-visible {
    outline: 3px solid rgb(var(--accent-rgb) / 0.24);
    outline-offset: 3px;
    border-radius: 6px;
  }

  .footer__copyright {
    margin: 0;
    color: rgb(var(--text-light-rgb) / 0.62);
    font-size: 14px;
    line-height: 20px;
  }

  @media (min-width: 1024px) {
    .footer {
      padding: 44px 0;
    }

    .footer__nav-link {
      font-size: 16px;
      line-height: 22px;
    }
  }
</style>
