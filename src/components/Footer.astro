---
type Props = {
  navItems: Array<{ text: string; href: string }>;
  links: Array<{ text: string; href: string }>;
  copyright: string;
};

const { navItems, links, copyright } = Astro.props;
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <nav class="footer__nav" aria-label="Навигация в подвале">
        <ul class="footer__nav-list">
          {navItems.map((item) => (
            <li class="footer__nav-item">
              <a class="footer__nav-link" href={item.href}>{item.text}</a>
            </li>
          ))}
        </ul>
      </nav>

      <p class="footer__copyright">{copyright}</p>
    </div>

    <div class="footer__bottom">
      <ul class="footer__links">
        {links.map((link) => (
          <li class="footer__links-item">
            <a class="footer__link" href={link.href}>{link.text}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-on-dark);
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 42px 0;
  }

  .footer__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    padding-bottom: 18px;
  }

  .footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer__nav-link {
    color: var(--muted-on-dark);
    transition: color 140ms ease;
  }

  .footer__nav-link:hover {
    color: var(--text-light);
  }

  .footer__copyright {
    margin: 0;
    color: var(--muted-on-dark);
  }

  .footer__bottom {
    border-top: 1px solid var(--border-on-dark);
    padding-top: 18px;
  }

  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer__link {
    text-decoration: underline;
    text-underline-offset: 3px;
    color: var(--muted-on-dark);
    transition: color 140ms ease;
  }

  .footer__link:hover {
    color: var(--text-light);
  }
</style>

