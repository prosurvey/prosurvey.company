<section class="theme-playground" aria-label="Панель подбора цветов">
  <div class="theme-playground__inner">
    <p class="theme-playground__title">Подбор цвета фона</p>

    <div class="theme-playground__controls">
      <label class="theme-playground__field">
        <span>R</span>
        <input id="themePlaygroundR" type="number" min="0" max="255" step="1" inputmode="numeric" />
      </label>

      <label class="theme-playground__field">
        <span>G</span>
        <input id="themePlaygroundG" type="number" min="0" max="255" step="1" inputmode="numeric" />
      </label>

      <label class="theme-playground__field">
        <span>B</span>
        <input id="themePlaygroundB" type="number" min="0" max="255" step="1" inputmode="numeric" />
      </label>

      <button class="btn btn-secondary theme-playground__reset" type="button" id="themePlaygroundReset">Сброс</button>
    </div>

    <div class="theme-playground__result">
      <div class="theme-playground__pair">
        <span>Фон:</span>
        <strong id="themePlaygroundBgHex">#0F172A</strong>
      </div>
      <div class="theme-playground__pair">
        <span>Акцент:</span>
        <strong id="themePlaygroundAccentHex">#2C61D6</strong>
      </div>
      <div class="theme-playground__swatches" aria-hidden="true">
        <span class="theme-playground__swatch theme-playground__swatch--bg" id="themePlaygroundBgSwatch"></span>
        <span class="theme-playground__swatch theme-playground__swatch--accent" id="themePlaygroundAccentSwatch"></span>
      </div>
    </div>
  </div>
</section>

<style>
  .theme-playground {
    background: var(--bg-light);
    color: var(--text-dark);
    border-top: 1px solid var(--border-on-light);
    padding: 20px 0 24px;
  }

  .theme-playground__inner {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: clamp(18px, 4vw, 32px);
    display: grid;
    gap: 14px;
  }

  .theme-playground__title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .theme-playground__controls {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 96px));
    gap: 10px;
    align-items: end;
  }

  .theme-playground__field {
    display: grid;
    gap: 6px;
    font-size: 12px;
    line-height: 1;
    color: var(--muted-on-light);
  }

  .theme-playground__field input {
    width: 100%;
    appearance: textfield;
    border: 1px solid rgb(var(--text-dark-rgb) / 0.2);
    border-radius: var(--radius-xs);
    background: #fff;
    color: var(--text-dark);
    padding: 8px 10px;
    font: inherit;
    line-height: 1.2;
  }

  .theme-playground__field input::-webkit-outer-spin-button,
  .theme-playground__field input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .theme-playground__field input:focus-visible,
  .theme-playground__reset:focus-visible {
    outline: 3px solid rgb(var(--accent-rgb) / 0.24);
    outline-offset: 2px;
  }

  .theme-playground__reset {
    justify-self: start;
    padding: 8px 12px;
    min-height: 38px;
  }

  .theme-playground__result {
    display: grid;
    gap: 8px;
  }

  .theme-playground__pair {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--muted-on-light);
  }

  .theme-playground__pair strong {
    color: var(--text-dark);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .theme-playground__swatches {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
  }

  .theme-playground__swatch {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1px solid rgb(var(--text-dark-rgb) / 0.14);
    box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.16);
  }

  .theme-playground__swatch--bg {
    background: var(--bg-dark);
  }

  .theme-playground__swatch--accent {
    background: var(--accent);
  }

  @media (min-width: 860px) {
    .theme-playground__inner {
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 12px 24px;
    }

    .theme-playground__controls {
      grid-template-columns: repeat(3, minmax(0, 84px)) auto;
      justify-content: start;
    }

    .theme-playground__result {
      justify-self: end;
      text-align: right;
    }

    .theme-playground__pair {
      justify-content: flex-end;
    }

    .theme-playground__swatches {
      justify-content: flex-end;
    }
  }
</style>

<script>
  const clampByte = (value) => {
    const parsed = Number.parseInt(String(value), 10);
    if (Number.isNaN(parsed)) return 0;
    return Math.max(0, Math.min(255, parsed));
  };

  const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

  const toHex = (rgb) =>
    `#${rgb
      .map((channel) => clampByte(channel).toString(16).padStart(2, "0"))
      .join("")
      .toUpperCase()}`;

  const toTriplet = (rgb) => rgb.map((channel) => clampByte(channel)).join(" ");

  const darken = (rgb, amount) => {
    const ratio = clamp(amount, 0, 1);
    return rgb.map((channel) => Math.round(clampByte(channel) * (1 - ratio)));
  };

  const parseCssColor = (value) => {
    if (!value) return null;
    const raw = String(value).trim();

    if (raw.startsWith("#")) {
      const hex = raw.slice(1);
      const normalized =
        hex.length === 3
          ? hex
              .split("")
              .map((char) => char + char)
              .join("")
          : hex.length === 6
            ? hex
            : null;

      if (!normalized) return null;

      const r = Number.parseInt(normalized.slice(0, 2), 16);
      const g = Number.parseInt(normalized.slice(2, 4), 16);
      const b = Number.parseInt(normalized.slice(4, 6), 16);

      if ([r, g, b].some((n) => Number.isNaN(n))) return null;
      return [r, g, b];
    }

    const rgbMatch = raw.match(/rgba?\(([^)]+)\)/i);
    if (!rgbMatch) return null;

    const channels = rgbMatch[1]
      .split(",")
      .slice(0, 3)
      .map((part) => clampByte(part.trim()));

    if (channels.length !== 3 || channels.some((n) => Number.isNaN(n))) return null;
    return channels;
  };

  const rgbToHsl = ([r, g, b]) => {
    const rn = clampByte(r) / 255;
    const gn = clampByte(g) / 255;
    const bn = clampByte(b) / 255;

    const max = Math.max(rn, gn, bn);
    const min = Math.min(rn, gn, bn);
    const delta = max - min;

    let h = 0;
    if (delta !== 0) {
      if (max === rn) h = ((gn - bn) / delta) % 6;
      else if (max === gn) h = (bn - rn) / delta + 2;
      else h = (rn - gn) / delta + 4;
      h = Math.round(h * 60);
      if (h < 0) h += 360;
    }

    const l = (max + min) / 2;
    const s = delta === 0 ? 0 : delta / (1 - Math.abs(2 * l - 1));

    return [h, s * 100, l * 100];
  };

  const hslToRgb = ([h, s, l]) => {
    const hue = ((h % 360) + 360) % 360;
    const sat = clamp(s, 0, 100) / 100;
    const lig = clamp(l, 0, 100) / 100;

    const c = (1 - Math.abs(2 * lig - 1)) * sat;
    const x = c * (1 - Math.abs(((hue / 60) % 2) - 1));
    const m = lig - c / 2;

    let rn = 0;
    let gn = 0;
    let bn = 0;

    if (hue < 60) [rn, gn, bn] = [c, x, 0];
    else if (hue < 120) [rn, gn, bn] = [x, c, 0];
    else if (hue < 180) [rn, gn, bn] = [0, c, x];
    else if (hue < 240) [rn, gn, bn] = [0, x, c];
    else if (hue < 300) [rn, gn, bn] = [x, 0, c];
    else [rn, gn, bn] = [c, 0, x];

    return [
      Math.round((rn + m) * 255),
      Math.round((gn + m) * 255),
      Math.round((bn + m) * 255),
    ];
  };

  const linearize = (channel) => {
    const normalized = clampByte(channel) / 255;
    return normalized <= 0.04045 ? normalized / 12.92 : ((normalized + 0.055) / 1.055) ** 2.4;
  };

  const luminance = (rgb) => {
    const [r, g, b] = rgb;
    return 0.2126 * linearize(r) + 0.7152 * linearize(g) + 0.0722 * linearize(b);
  };

  const contrastRatio = (a, b) => {
    const la = luminance(a);
    const lb = luminance(b);
    const light = Math.max(la, lb);
    const dark = Math.min(la, lb);
    return (light + 0.05) / (dark + 0.05);
  };

  const deriveAccentFromBg = (bgRgb, textOnAccentRgb) => {
    const [h, s, l] = rgbToHsl(bgRgb);

    const hue = (h + 24) % 360;
    const saturation = clamp(Math.max(70, s * 1.25 + 14), 64, 95);
    let lightness = clamp(56 + (24 - l) * 0.16, 44, 66);

    for (let i = 0; i < 40; i += 1) {
      const candidate = hslToRgb([hue, saturation, lightness]);
      if (contrastRatio(candidate, bgRgb) >= 3) break;
      lightness = clamp(lightness + 1, 24, 80);
    }

    for (let i = 0; i < 40; i += 1) {
      const candidate = hslToRgb([hue, saturation, lightness]);
      if (contrastRatio(candidate, textOnAccentRgb) >= 4.5) break;
      lightness = clamp(lightness - 1, 24, 80);
    }

    return hslToRgb([hue, saturation, lightness]);
  };

  const readThemeRgb = (styles, name, fallback) => parseCssColor(styles.getPropertyValue(name)) ?? fallback;

  const initThemePlayground = () => {
    const root = document.querySelector(".theme-playground");
    if (!root) return;

    const inputR = root.querySelector("#themePlaygroundR");
    const inputG = root.querySelector("#themePlaygroundG");
    const inputB = root.querySelector("#themePlaygroundB");
    const resetButton = root.querySelector("#themePlaygroundReset");
    const bgHexNode = root.querySelector("#themePlaygroundBgHex");
    const accentHexNode = root.querySelector("#themePlaygroundAccentHex");
    const bgSwatch = root.querySelector("#themePlaygroundBgSwatch");
    const accentSwatch = root.querySelector("#themePlaygroundAccentSwatch");

    if (!inputR || !inputG || !inputB || !resetButton || !bgHexNode || !accentHexNode || !bgSwatch || !accentSwatch) return;

    const styles = getComputedStyle(document.body);
    const defaultBg = readThemeRgb(styles, "--bg-dark", [15, 23, 42]);
    const textOnAccent = readThemeRgb(styles, "--text-light", [248, 250, 252]);

    const setInputValues = (rgb) => {
      inputR.value = String(rgb[0]);
      inputG.value = String(rgb[1]);
      inputB.value = String(rgb[2]);
    };

    const renderPreview = (bgRgb, accentRgb) => {
      const bgHex = toHex(bgRgb);
      const accentHex = toHex(accentRgb);

      bgHexNode.textContent = bgHex;
      accentHexNode.textContent = accentHex;
      bgSwatch.style.background = bgHex;
      accentSwatch.style.background = accentHex;
    };

    const applyTheme = (bgRgb) => {
      const accentRgb = deriveAccentFromBg(bgRgb, textOnAccent);

      document.body.style.setProperty("--bg-dark", toHex(bgRgb));
      document.body.style.setProperty("--bg-dark-rgb", toTriplet(bgRgb));
      document.body.style.setProperty("--accent", toHex(accentRgb));
      document.body.style.setProperty("--accent-rgb", toTriplet(accentRgb));
      document.body.style.setProperty("--accent-hover", toHex(darken(accentRgb, 0.12)));
      document.body.style.setProperty("--accent-active", toHex(darken(accentRgb, 0.24)));

      renderPreview(bgRgb, accentRgb);
    };

    const readInputs = () => [clampByte(inputR.value), clampByte(inputG.value), clampByte(inputB.value)];

    setInputValues(defaultBg);
    applyTheme(defaultBg);

    [inputR, inputG, inputB].forEach((input) => {
      input.addEventListener("input", () => {
        const nextBg = readInputs();
        setInputValues(nextBg);
        applyTheme(nextBg);
      });

      input.addEventListener("blur", () => {
        const nextBg = readInputs();
        setInputValues(nextBg);
      });
    });

    resetButton.addEventListener("click", () => {
      setInputValues(defaultBg);
      applyTheme(defaultBg);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initThemePlayground, { once: true });
  } else {
    initThemePlayground();
  }
</script>
