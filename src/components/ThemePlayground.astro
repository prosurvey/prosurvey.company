<section class="theme-playground" aria-label="Панель подбора цветов">
  <div class="theme-playground__inner">
    <p class="theme-playground__title">Подбор цвета</p>

    <div class="theme-playground__group" aria-label="Цвет фона">
      <p class="theme-playground__group-title">Фон (RGB)</p>

      <label class="theme-playground__channel" for="themePlaygroundBgRNumber">
        <span>R</span>
        <input id="themePlaygroundBgRRange" type="range" min="0" max="255" step="1" />
        <input
          id="themePlaygroundBgRNumber"
          type="number"
          min="0"
          max="255"
          step="1"
          inputmode="numeric"
        />
      </label>

      <label class="theme-playground__channel" for="themePlaygroundBgGNumber">
        <span>G</span>
        <input id="themePlaygroundBgGRange" type="range" min="0" max="255" step="1" />
        <input
          id="themePlaygroundBgGNumber"
          type="number"
          min="0"
          max="255"
          step="1"
          inputmode="numeric"
        />
      </label>

      <label class="theme-playground__channel" for="themePlaygroundBgBNumber">
        <span>B</span>
        <input id="themePlaygroundBgBRange" type="range" min="0" max="255" step="1" />
        <input
          id="themePlaygroundBgBNumber"
          type="number"
          min="0"
          max="255"
          step="1"
          inputmode="numeric"
        />
      </label>
    </div>

    <div class="theme-playground__group" aria-label="Акцентный цвет">
      <p class="theme-playground__group-title">Акцент (RGB)</p>

      <label class="theme-playground__toggle" for="themePlaygroundAutoAccent">
        <input id="themePlaygroundAutoAccent" type="checkbox" checked />
        <span>Высчитать акцентный цвет автоматически</span>
      </label>

      <label class="theme-playground__channel" for="themePlaygroundAccentRNumber">
        <span>R</span>
        <input id="themePlaygroundAccentRRange" type="range" min="0" max="255" step="1" />
        <input
          id="themePlaygroundAccentRNumber"
          type="number"
          min="0"
          max="255"
          step="1"
          inputmode="numeric"
        />
      </label>

      <label class="theme-playground__channel" for="themePlaygroundAccentGNumber">
        <span>G</span>
        <input id="themePlaygroundAccentGRange" type="range" min="0" max="255" step="1" />
        <input
          id="themePlaygroundAccentGNumber"
          type="number"
          min="0"
          max="255"
          step="1"
          inputmode="numeric"
        />
      </label>

      <label class="theme-playground__channel" for="themePlaygroundAccentBNumber">
        <span>B</span>
        <input id="themePlaygroundAccentBRange" type="range" min="0" max="255" step="1" />
        <input
          id="themePlaygroundAccentBNumber"
          type="number"
          min="0"
          max="255"
          step="1"
          inputmode="numeric"
        />
      </label>
    </div>

    <div class="theme-playground__footer">
      <div class="theme-playground__result">
        <div class="theme-playground__pair">
          <span>Фон:</span>
          <strong id="themePlaygroundBgHex">#0F172A</strong>
        </div>

        <div class="theme-playground__pair">
          <span>Акцент:</span>
          <strong id="themePlaygroundAccentHex">#2C61D6</strong>
        </div>

        <div class="theme-playground__swatches" aria-hidden="true">
          <span class="theme-playground__swatch" id="themePlaygroundBgSwatch"></span>
          <span class="theme-playground__swatch" id="themePlaygroundAccentSwatch"></span>
        </div>
      </div>

      <button class="btn btn-secondary theme-playground__reset" type="button" id="themePlaygroundReset">Сброс</button>
    </div>
  </div>
</section>

<style>
  .theme-playground {
    background: var(--bg-light);
    color: var(--text-dark);
    border-top: 1px solid var(--border-on-light);
    padding: 18px 0 24px;
  }

  .theme-playground__inner {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding-inline: clamp(18px, 4vw, 32px);
    display: grid;
    gap: 16px;
  }

  .theme-playground__title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  .theme-playground__group {
    display: grid;
    gap: 10px;
    padding: 12px;
    border: 1px solid rgb(var(--text-dark-rgb) / 0.12);
    border-radius: var(--radius-sm);
    background: #fff;
  }

  .theme-playground__group-title {
    margin: 0;
    font-size: 13px;
    line-height: 1.2;
    font-weight: 600;
    color: var(--muted-on-light);
  }

  .theme-playground__toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    line-height: 1.4;
    color: var(--text-dark);
  }

  .theme-playground__toggle input {
    inline-size: 16px;
    block-size: 16px;
  }

  .theme-playground__channel {
    display: grid;
    grid-template-columns: 18px 1fr 68px;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--muted-on-light);
  }

  .theme-playground__channel input[type="range"] {
    width: 100%;
    margin: 0;
    accent-color: var(--accent);
  }

  .theme-playground__channel input[type="number"] {
    width: 100%;
    appearance: textfield;
    border: 1px solid rgb(var(--text-dark-rgb) / 0.2);
    border-radius: var(--radius-xs);
    padding: 5px 8px;
    background: #fff;
    color: var(--text-dark);
    font: inherit;
    line-height: 1.2;
  }

  .theme-playground__channel input[type="number"]::-webkit-outer-spin-button,
  .theme-playground__channel input[type="number"]::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .theme-playground__channel input[type="range"]:disabled,
  .theme-playground__channel input[type="number"]:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .theme-playground__channel input:focus-visible,
  .theme-playground__toggle input:focus-visible,
  .theme-playground__reset:focus-visible {
    outline: 3px solid rgb(var(--accent-rgb) / 0.24);
    outline-offset: 2px;
  }

  .theme-playground__footer {
    display: grid;
    gap: 10px;
  }

  .theme-playground__result {
    display: grid;
    gap: 6px;
  }

  .theme-playground__pair {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--muted-on-light);
  }

  .theme-playground__pair strong {
    color: var(--text-dark);
    letter-spacing: 0.02em;
    font-weight: 600;
  }

  .theme-playground__swatches {
    display: inline-flex;
    gap: 8px;
    margin-top: 2px;
  }

  .theme-playground__swatch {
    width: 26px;
    height: 26px;
    border-radius: 999px;
    border: 1px solid rgb(var(--text-dark-rgb) / 0.14);
    box-shadow: inset 0 1px 2px rgb(0 0 0 / 0.16);
  }

  .theme-playground__reset {
    justify-self: start;
    padding: 8px 12px;
    min-height: 36px;
  }

  @media (min-width: 940px) {
    .theme-playground__inner {
      grid-template-columns: 1fr 1fr auto;
      align-items: start;
      gap: 14px;
    }

    .theme-playground__title {
      grid-column: 1 / -1;
    }

    .theme-playground__footer {
      align-self: stretch;
      grid-template-rows: 1fr auto;
      justify-items: end;
      min-width: 180px;
    }

    .theme-playground__result {
      text-align: right;
    }

    .theme-playground__pair {
      justify-content: flex-end;
    }

    .theme-playground__swatches {
      justify-content: flex-end;
    }

    .theme-playground__reset {
      justify-self: end;
    }
  }
</style>

<script>
  const clampByte = (value) => {
    const parsed = Number.parseInt(String(value), 10);
    if (Number.isNaN(parsed)) return 0;
    return Math.max(0, Math.min(255, parsed));
  };

  const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

  const toHex = (rgb) =>
    `#${rgb
      .map((channel) => clampByte(channel).toString(16).padStart(2, "0"))
      .join("")
      .toUpperCase()}`;

  const toTriplet = (rgb) => rgb.map((channel) => clampByte(channel)).join(" ");

  const darken = (rgb, amount) => {
    const ratio = clamp(amount, 0, 1);
    return rgb.map((channel) => Math.round(clampByte(channel) * (1 - ratio)));
  };

  const parseCssColor = (value) => {
    if (!value) return null;
    const raw = String(value).trim();

    if (raw.startsWith("#")) {
      const hex = raw.slice(1);
      const normalized =
        hex.length === 3
          ? hex
              .split("")
              .map((char) => char + char)
              .join("")
          : hex.length === 6
            ? hex
            : null;

      if (!normalized) return null;

      const r = Number.parseInt(normalized.slice(0, 2), 16);
      const g = Number.parseInt(normalized.slice(2, 4), 16);
      const b = Number.parseInt(normalized.slice(4, 6), 16);

      if ([r, g, b].some((channel) => Number.isNaN(channel))) return null;
      return [r, g, b];
    }

    const rgbMatch = raw.match(/rgba?\(([^)]+)\)/i);
    if (!rgbMatch) return null;

    const channels = rgbMatch[1]
      .replace(/\//g, " ")
      .split(/[,\s]+/)
      .filter(Boolean)
      .slice(0, 3)
      .map((part) => clampByte(part.trim()));

    if (channels.length !== 3 || channels.some((channel) => Number.isNaN(channel))) return null;
    return channels;
  };

  const rgbToHsl = ([r, g, b]) => {
    const rn = clampByte(r) / 255;
    const gn = clampByte(g) / 255;
    const bn = clampByte(b) / 255;

    const max = Math.max(rn, gn, bn);
    const min = Math.min(rn, gn, bn);
    const delta = max - min;

    let h = 0;
    if (delta !== 0) {
      if (max === rn) h = ((gn - bn) / delta) % 6;
      else if (max === gn) h = (bn - rn) / delta + 2;
      else h = (rn - gn) / delta + 4;
      h = Math.round(h * 60);
      if (h < 0) h += 360;
    }

    const l = (max + min) / 2;
    const s = delta === 0 ? 0 : delta / (1 - Math.abs(2 * l - 1));
    return [h, s * 100, l * 100];
  };

  const hslToRgb = ([h, s, l]) => {
    const hue = ((h % 360) + 360) % 360;
    const sat = clamp(s, 0, 100) / 100;
    const lig = clamp(l, 0, 100) / 100;

    const c = (1 - Math.abs(2 * lig - 1)) * sat;
    const x = c * (1 - Math.abs(((hue / 60) % 2) - 1));
    const m = lig - c / 2;

    let rn = 0;
    let gn = 0;
    let bn = 0;

    if (hue < 60) [rn, gn, bn] = [c, x, 0];
    else if (hue < 120) [rn, gn, bn] = [x, c, 0];
    else if (hue < 180) [rn, gn, bn] = [0, c, x];
    else if (hue < 240) [rn, gn, bn] = [0, x, c];
    else if (hue < 300) [rn, gn, bn] = [x, 0, c];
    else [rn, gn, bn] = [c, 0, x];

    return [
      Math.round((rn + m) * 255),
      Math.round((gn + m) * 255),
      Math.round((bn + m) * 255),
    ];
  };

  const linearize = (channel) => {
    const normalized = clampByte(channel) / 255;
    return normalized <= 0.04045 ? normalized / 12.92 : ((normalized + 0.055) / 1.055) ** 2.4;
  };

  const luminance = (rgb) => {
    const [r, g, b] = rgb;
    return 0.2126 * linearize(r) + 0.7152 * linearize(g) + 0.0722 * linearize(b);
  };

  const contrastRatio = (a, b) => {
    const la = luminance(a);
    const lb = luminance(b);
    const light = Math.max(la, lb);
    const dark = Math.min(la, lb);
    return (light + 0.05) / (dark + 0.05);
  };

  const deriveAccentFromBg = (bgRgb, textOnAccentRgb) => {
    const [h, s, l] = rgbToHsl(bgRgb);

    const hue = (h + 24) % 360;
    const saturation = clamp(Math.max(70, s * 1.25 + 14), 64, 95);
    let lightness = clamp(56 + (24 - l) * 0.16, 44, 66);

    for (let i = 0; i < 40; i += 1) {
      const candidate = hslToRgb([hue, saturation, lightness]);
      if (contrastRatio(candidate, bgRgb) >= 3) break;
      lightness = clamp(lightness + 1, 24, 80);
    }

    for (let i = 0; i < 40; i += 1) {
      const candidate = hslToRgb([hue, saturation, lightness]);
      if (contrastRatio(candidate, textOnAccentRgb) >= 4.5) break;
      lightness = clamp(lightness - 1, 24, 80);
    }

    return hslToRgb([hue, saturation, lightness]);
  };

  const readThemeRgb = (styles, name, fallback) => parseCssColor(styles.getPropertyValue(name)) ?? fallback;

  const sameRgb = (a, b) => a.length === b.length && a.every((value, index) => value === b[index]);

  const initThemePlayground = () => {
    const root = document.querySelector(".theme-playground");
    if (!root) return;

    const el = {
      bg: {
        rRange: root.querySelector("#themePlaygroundBgRRange"),
        gRange: root.querySelector("#themePlaygroundBgGRange"),
        bRange: root.querySelector("#themePlaygroundBgBRange"),
        rNumber: root.querySelector("#themePlaygroundBgRNumber"),
        gNumber: root.querySelector("#themePlaygroundBgGNumber"),
        bNumber: root.querySelector("#themePlaygroundBgBNumber"),
      },
      accent: {
        rRange: root.querySelector("#themePlaygroundAccentRRange"),
        gRange: root.querySelector("#themePlaygroundAccentGRange"),
        bRange: root.querySelector("#themePlaygroundAccentBRange"),
        rNumber: root.querySelector("#themePlaygroundAccentRNumber"),
        gNumber: root.querySelector("#themePlaygroundAccentGNumber"),
        bNumber: root.querySelector("#themePlaygroundAccentBNumber"),
      },
      autoAccent: root.querySelector("#themePlaygroundAutoAccent"),
      resetButton: root.querySelector("#themePlaygroundReset"),
      bgHexNode: root.querySelector("#themePlaygroundBgHex"),
      accentHexNode: root.querySelector("#themePlaygroundAccentHex"),
      bgSwatch: root.querySelector("#themePlaygroundBgSwatch"),
      accentSwatch: root.querySelector("#themePlaygroundAccentSwatch"),
    };

    const allInputs = [
      el.bg.rRange,
      el.bg.gRange,
      el.bg.bRange,
      el.bg.rNumber,
      el.bg.gNumber,
      el.bg.bNumber,
      el.accent.rRange,
      el.accent.gRange,
      el.accent.bRange,
      el.accent.rNumber,
      el.accent.gNumber,
      el.accent.bNumber,
      el.autoAccent,
      el.resetButton,
      el.bgHexNode,
      el.accentHexNode,
      el.bgSwatch,
      el.accentSwatch,
    ];

    if (allInputs.some((node) => !node)) return;

    const styles = getComputedStyle(document.body);
    const defaultBg = readThemeRgb(styles, "--bg-dark", [15, 23, 42]);
    const defaultAccent = readThemeRgb(styles, "--accent", [44, 97, 214]);
    const textOnAccent = readThemeRgb(styles, "--text-light", [248, 250, 252]);

    const state = {
      bg: [...defaultBg],
      accent: [...defaultAccent],
      autoAccent: true,
    };

    const channels = ["r", "g", "b"];

    const setTripletControls = (controls, rgb) => {
      channels.forEach((key, index) => {
        controls[`${key}Range`].value = String(rgb[index]);
        controls[`${key}Number`].value = String(rgb[index]);
      });
    };

    const setAccentControlsDisabled = (disabled) => {
      channels.forEach((key) => {
        controlsSetDisabled(el.accent[`${key}Range`], disabled);
        controlsSetDisabled(el.accent[`${key}Number`], disabled);
      });
    };

    const controlsSetDisabled = (node, disabled) => {
      node.disabled = disabled;
    };

    const readTripletFromControls = (controls) =>
      channels.map((key) => clampByte(controls[`${key}Number`].value || controls[`${key}Range`].value));

    const writeThemeVars = (bgRgb, accentRgb) => {
      document.body.style.setProperty("--bg-dark", toHex(bgRgb));
      document.body.style.setProperty("--bg-dark-rgb", toTriplet(bgRgb));
      document.body.style.setProperty("--accent", toHex(accentRgb));
      document.body.style.setProperty("--accent-rgb", toTriplet(accentRgb));
      document.body.style.setProperty("--accent-hover", toHex(darken(accentRgb, 0.12)));
      document.body.style.setProperty("--accent-active", toHex(darken(accentRgb, 0.24)));
    };

    const render = () => {
      const bgRgb = state.bg.map((value) => clampByte(value));
      const accentRgb = state.autoAccent
        ? sameRgb(bgRgb, defaultBg)
          ? [...defaultAccent]
          : deriveAccentFromBg(bgRgb, textOnAccent)
        : state.accent.map((value) => clampByte(value));

      state.bg = bgRgb;
      state.accent = accentRgb;

      setTripletControls(el.bg, bgRgb);
      setTripletControls(el.accent, accentRgb);
      setAccentControlsDisabled(state.autoAccent);
      el.autoAccent.checked = state.autoAccent;

      const bgHex = toHex(bgRgb);
      const accentHex = toHex(accentRgb);

      el.bgHexNode.textContent = bgHex;
      el.accentHexNode.textContent = accentHex;
      el.bgSwatch.style.background = bgHex;
      el.accentSwatch.style.background = accentHex;

      writeThemeVars(bgRgb, accentRgb);
    };

    const bindTripletControls = (controls, onChange) => {
      channels.forEach((key, index) => {
        const range = controls[`${key}Range`];
        const number = controls[`${key}Number`];

        const applyFromRange = () => {
          const value = clampByte(range.value);
          number.value = String(value);
          onChange(index, value);
        };

        const applyFromNumber = () => {
          const value = clampByte(number.value);
          number.value = String(value);
          range.value = String(value);
          onChange(index, value);
        };

        range.addEventListener("input", applyFromRange);
        number.addEventListener("input", applyFromNumber);
        number.addEventListener("blur", applyFromNumber);
      });
    };

    bindTripletControls(el.bg, (index, value) => {
      state.bg[index] = value;
      render();
    });

    bindTripletControls(el.accent, (index, value) => {
      if (state.autoAccent) return;
      state.accent[index] = value;
      render();
    });

    el.autoAccent.addEventListener("change", () => {
      state.autoAccent = el.autoAccent.checked;
      if (!state.autoAccent) {
        state.accent = readTripletFromControls(el.accent);
      }
      render();
    });

    el.resetButton.addEventListener("click", () => {
      state.bg = [...defaultBg];
      state.accent = [...defaultAccent];
      state.autoAccent = true;
      render();
    });

    render();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initThemePlayground, { once: true });
  } else {
    initThemePlayground();
  }
</script>
