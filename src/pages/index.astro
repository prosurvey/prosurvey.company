---
import BaseLayout from "../layouts/BaseLayout.astro";
import CookieBanner from "../components/CookieBanner.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ThemePlayground from "../components/ThemePlayground.astro";
import About from "../components/sections/About.astro";
import Certifications from "../components/sections/Certifications.astro";
import Contacts from "../components/sections/Contacts.astro";
import Hero from "../components/sections/Hero.astro";
import Request from "../components/sections/Request.astro";
import Services from "../components/sections/Services.astro";
import { loadHomePageModel } from "../lib/content";

const pageModel = await loadHomePageModel();
---

<BaseLayout
  lang={pageModel.layout.lang}
  title={pageModel.layout.title}
  description={pageModel.layout.description}
  keywords={pageModel.layout.keywords}
  faviconHref={pageModel.layout.faviconHref}
  theme={pageModel.layout.theme}
>
  <Header
    logoHref={pageModel.header.logoHref}
    logoAlt={pageModel.header.logoAlt}
    navItems={pageModel.header.navItems}
    cta={pageModel.header.cta}
  />

  <main id="top">
    <Hero
      title={pageModel.hero.title}
      text={pageModel.hero.text}
      imageHref={pageModel.hero.imageHref}
      buttons={pageModel.hero.buttons}
    />

    <About
      id={pageModel.about.id}
      eyebrow={pageModel.about.eyebrow}
      title={pageModel.about.title}
      text={pageModel.about.text}
      stats={pageModel.about.stats}
      note={pageModel.about.note}
    />

    <Services
      id={pageModel.services.id}
      title={pageModel.services.title}
      subtitle={pageModel.services.subtitle}
      main={pageModel.services.main}
      other={pageModel.services.other}
    />

    <Request
      id={pageModel.request.id}
      title={pageModel.request.title}
      description={pageModel.request.description}
      imageHref={pageModel.request.imageHref}
      submitText={pageModel.request.submitText}
      fields={pageModel.request.fields}
      messages={pageModel.request.messages}
      consentLinks={pageModel.request.consentLinks}
    />

    <Certifications
      id={pageModel.certifications.id}
      title={pageModel.certifications.title}
      items={pageModel.certifications.items}
    />

    <Contacts
      id={pageModel.contacts.id}
      title={pageModel.contacts.title}
      email={pageModel.contacts.email}
      phoneText={pageModel.contacts.phoneText}
      phoneHref={pageModel.contacts.phoneHref}
      hours={pageModel.contacts.hours}
      socials={pageModel.contacts.socials}
    />
  </main>

  <Footer
    navItems={pageModel.footer.navItems}
    links={pageModel.footer.links}
    copyright={pageModel.footer.copyright}
  />
  <ThemePlayground />

  {pageModel.cookie.enabled ? (
    <CookieBanner text={pageModel.cookie.text} acceptText={pageModel.cookie.acceptText} link={pageModel.cookie.link} />
  ) : null}
</BaseLayout>
